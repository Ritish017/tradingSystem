PYTHON_VERSION=3.11
NODE_VERSION=20

# Core service ports
BACKEND_PORT=8000
FRONTEND_PORT=3000
POSTGRES_PORT=5432
REDIS_PORT=6379
INFLUXDB_PORT=8086
REDPANDA_BROKER_PORT=9092
MLFLOW_PORT=5000
GRAFANA_PORT=3001
OPENALGO_PORT=5050

# Backend runtime
APP_ENV=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
JWT_SECRET=change-me
JWT_ALGORITHM=HS256

# PostgreSQL
POSTGRES_USER=trading
POSTGRES_PASSWORD=trading
POSTGRES_DB=trading
DATABASE_URL=postgresql+asyncpg://trading:trading@postgres:5432/trading

# Redis
REDIS_URL=redis://redis:6379/0

# InfluxDB 2.x
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_TOKEN=local-dev-token
INFLUXDB_ORG=trading
INFLUXDB_BUCKET=ticks
DOCKER_INFLUXDB_INIT_MODE=setup
DOCKER_INFLUXDB_INIT_USERNAME=admin
DOCKER_INFLUXDB_INIT_PASSWORD=adminadmin
DOCKER_INFLUXDB_INIT_ORG=trading
DOCKER_INFLUXDB_INIT_BUCKET=ticks
DOCKER_INFLUXDB_INIT_ADMIN_TOKEN=local-dev-token

# Redpanda / Kafka
REDPANDA_BROKERS=redpanda:9092
REDPANDA_PROXY_URL=http://redpanda:8082/v1
PUBLISH_TICKS_TO_EXTERNAL=true

# MLflow
MLFLOW_TRACKING_URI=http://mlflow:5000
GRAFANA_URL=http://grafana:3000

# OpenAlgo
OPENALGO_BASE_URL=http://openalgo:5000
OPENALGO_API_KEY=change-me

# India brokers (fill what you use)
KITE_WS_ENABLED=false
KITE_API_KEY=
KITE_API_SECRET=
KITE_ACCESS_TOKEN=
SHOONYA_USER=
SHOONYA_PASSWORD=
SHOONYA_TOTP_SECRET=
UPSTOX_API_KEY=
UPSTOX_API_SECRET=
ANGEL_API_KEY=
ANGEL_CLIENT_ID=
ANGEL_PIN=
ANGEL_TOTP_SECRET=

# Crypto exchanges (fill what you use)
BINANCE_WS_URL=wss://stream.binance.com:9443/stream
BINANCE_API_KEY=
BINANCE_API_SECRET=
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=
COINDCX_API_KEY=
COINDCX_API_SECRET=
WAZIRX_API_KEY=
WAZIRX_API_SECRET=


# Free Data Mode (no API keys needed)
USE_FREE_DATA=true
FREE_DATA_UPDATE_INTERVAL=60

# Hybrid Engine
LLM_ENDPOINT=http://localhost:8080/v1/chat/completions
LLM_MODEL=nvidia/llama-3.1-nemotron-ultra-253b-v1
LLM_API_KEY=
MIN_SIGNAL_CONFIDENCE=0.6
MAX_SIGNAL_AGE_SECONDS=300
SIGNAL_CONFLICT_THRESHOLD=0.5

# NVIDIA Nemotron Multi-Model Routing
# Get your API key at: https://build.nvidia.com (free tier: 1000 credits, 40 req/min)
NVIDIA_API_KEY=nvapi-<your-key-here>
SUPER_MODEL=nvidia/nemotron-3-super-120b-a12b
NANO_MODEL=nvidia/nemotron-3-nano-30b-a3b
NEMOTRON_BASE_URL=https://integrate.api.nvidia.com/v1
